{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "strict": true,
    "skipLibCheck": true,

    "resolveJsonModule": true,
    "esModuleInterop": true,

    "types": ["node"],

    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
